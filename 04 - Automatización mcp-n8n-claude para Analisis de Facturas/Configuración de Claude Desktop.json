{
    "mcpServers": {
        "n8n-facturas": {
            "command": "cmd.exe",
            "args": [
                "/c",
                "npx",
                "mcp-remote",
                "http://localhost:5678/mcp/facturas-mcp",
                "--header",
                "Authorization: Bearer <n8n_token>"
            ],
            "env": {
                "AUTH_TOKEN": "<n8n_token>"
            }
        }
    },
    "preferences": {
        "coworkScheduledTasksEnabled": false,
        "ccdScheduledTasksEnabled": false,
        "sidebarMode": "chat",
        "coworkWebSearchEnabled": true,
        "floatingAtollActive": true
    }
}